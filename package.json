{
  "name": "currency-calculator",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "env -u CI bash -lc 'PID=$(lsof -ti tcp:8081); if [ -n \"$PID\" ]; then kill $PID; fi; expo start --dev-client --host lan --port 8081 --clear'",
    "ios:device": "env -u CI LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 SSL_CERT_FILE=\"$(brew --prefix ca-certificates)/share/ca-certificates/cacert.pem\" RCT_METRO_PORT=8081 expo run:ios --device \"00008150-001E79A21A12401C\" --no-bundler",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "CI=0 expo start --web --port 8081"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-text-recognition": "^0.1.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-adapty": "^3.15.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "tslib": "^2.8.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
